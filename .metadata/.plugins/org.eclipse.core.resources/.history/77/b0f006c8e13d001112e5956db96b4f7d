package FlowControl;

public class Array {

	public static void main(String[] args) {
		int ar[] = new int [3];
		System.out.println(ar[0]);
		System.out.println(ar[1]);
		System.out.println(ar[2]);
		
		ar[1] = 2;
		ar[2]= 4;
		ar[0] = 6;
		
		for(int i=0;i<ar.length;++i) {
			System.out.print(ar[1]);
		}
		
		for(int j: ar) {
			System.out.println(j+ " ");

		}
	}

}
