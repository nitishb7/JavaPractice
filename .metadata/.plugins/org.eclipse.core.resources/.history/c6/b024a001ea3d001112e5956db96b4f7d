package FlowControl;
import java.util.*;

public class MultiDArray {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int ar[][] = new int[3][3];

        // Input
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                System.out.print("Enter number: ");
                ar[i][j] = sc.nextInt();   // ✅ fixed
            }
        }

        // Output
        System.out.println("\nMatrix:");
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                System.out.print(ar[i][j] + " ");  // ✅ fixed
            }
            System.out.println();
        }
    }
}